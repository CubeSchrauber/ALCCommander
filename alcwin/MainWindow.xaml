<Window x:Class="alcwin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        SizeToContent="WidthAndHeight"
        Style="{StaticResource WindowDefault}"
        Title="ALC 8500 Commander" d:DesignHeight="682" d:DesignWidth="1127.333">
    <Grid Margin="8">
        <Grid.Resources>
            <Style TargetType="Border" BasedOn="{StaticResource DefaultBorder}"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.ColumnSpan="4" Height="60" Margin="0 0 0 8" Background="Wheat">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="{StaticResource IconDrawingImage}"/>
                <TextBlock Grid.Column="1" Text="ALC 8500 Commander" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource BigText}" Foreground="DarkBlue" Margin="32 0 0 0"/>
                <Button Style="{StaticResource AlcButtonStyle}" Padding="2" ToolTip="Geräteparameter" Grid.Column="2" HorizontalAlignment="Right" Width="100" Click="Device_Click">
                    <Image Source="{StaticResource DeviceDrawingImage}"/>
                </Button>
                <Button Style="{StaticResource AlcButtonStyle}" Padding="2" ToolTip="Datenbank" Grid.Column="4" HorizontalAlignment="Right" Width="100" Click="Database_Click">
                    <Image Source="{StaticResource DatabaseDrawingImage}"/>
                </Button>
            </Grid>
        </Border>
        <Border Grid.Row="1" Grid.Column="0">
            <local:ChannelControl x:Name="Channel1" VerticalAlignment="Center" HorizontalAlignment="Center" Caption="1" Channel="0" ChargeState="3" EditEvent="Channel_Edit" StartEvent="Channel_Start" StopEvent="Channel_Stop" LogEvent="Channel_Log" FunctionEvent="SetFunction"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Margin="4 0 0 0">
            <local:ChannelControl x:Name="Channel2" VerticalAlignment="Center" HorizontalAlignment="Center" Caption="2" Channel="1" EditEvent="Channel_Edit" StartEvent="Channel_Start" StopEvent="Channel_Stop" LogEvent="Channel_Log" FunctionEvent="SetFunction"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="2" Margin="4 0 0 0">
            <local:ChannelControl x:Name="Channel3" VerticalAlignment="Center" HorizontalAlignment="Center" Caption="3" Channel="2" EditEvent="Channel_Edit" StartEvent="Channel_Start" StopEvent="Channel_Stop" LogEvent="Channel_Log" FunctionEvent="SetFunction"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="3" Margin="4 0 0 0">
            <local:ChannelControl x:Name="Channel4" VerticalAlignment="Center" HorizontalAlignment="Center" Caption="4" Channel="3" EditEvent="Channel_Edit" StartEvent="Channel_Start" StopEvent="Channel_Stop" LogEvent="Channel_Log" FunctionEvent="SetFunction"/>
        </Border>
    </Grid>
</Window>
