<Window x:Class="alcwin.ChannelLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Style="{StaticResource WindowDefault}"
        Title="Log" Height="450" Width="800">
    <Window.CommandBindings>
        <CommandBinding Command="local:ChannelLogWindow.GraphCommand" Executed="Graph_Executed"/>
        <CommandBinding Command="local:ChannelLogWindow.TextCommand" Executed="Text_Executed"/>
    </Window.CommandBindings>
    <Window.Resources>
        <local:VoltageToFloat x:Key="VoltageToFloat"/>
        <local:LogTimeConverter x:Key="LogTimeConverter"/>
    </Window.Resources>
    <Grid>
        <Grid x:Name="MainData" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource DefaultBorder}" Margin="8">
                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Background="Wheat" Margin="0 4" Padding="5" CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="{StaticResource ChannelDrawingImage}" Height="40"/>
                            <TextBlock Grid.Column="1" x:Name="CaptionText" Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=Channel, Mode=OneWay}"  HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontWeight="Bold" />
                        </Grid>
                    </Border>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Funktion:" Style="{DynamicResource Caption}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" MinWidth="140" x:Name="Program" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Left" Grid.ColumnSpan="2" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Akkutyp:" Style="{DynamicResource Caption}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" MinWidth="100" x:Name="BatType" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Left" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Spannung:" Style="{DynamicResource Caption}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" MinWidth="100" x:Name="Voltage" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="V" Style="{DynamicResource Caption}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Kapazität:" Style="{StaticResource Caption}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" MinWidth="100" x:Name="Capacity" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right" />
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="mAh" Style="{DynamicResource Caption}"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ladestrom:" Style="{StaticResource Caption}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" MinWidth="100" x:Name="ChargeCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Formierstrom:" Style="{StaticResource Caption}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" MinWidth="100" x:Name="FormingCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Entladestrom:" Style="{StaticResource Caption}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" MinWidth="100" x:Name="DischargeCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Pause:" Style="{StaticResource Caption}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" MinWidth="100" x:Name="Pause" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="min" Style="{DynamicResource Caption}"/>
                </Grid>
            </Border>
            <Grid Grid.Column="1">
                <Grid.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                        <Setter Property="Margin" Value="0 2"/>
                        <Setter Property="Height" Value="48"/>
                    </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="1" Command="local:ChannelLogWindow.GraphCommand">
                    <Image Source="{StaticResource LogDrawingImage}"/>
                </Button>
                <Button Grid.Row="2" Command="local:ChannelLogWindow.TextCommand">
                    <Image Source="{StaticResource Log2DrawingImage}"/>
                </Button>
            </Grid>
            <Border Background="White" Grid.Column="2" Style="{StaticResource DefaultBorder}" Margin="8" BorderThickness="1" >
                <Grid>
                    <local:ChartControl x:Name="Chart" Visibility="Visible"/>
                    <ListBox x:Name="Records" Style="{DynamicResource DbListBoxStyle}" ItemsSource="{Binding Data}" Visibility="Hidden">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" HorizontalAlignment="Right" Margin="0 0 4 0" Foreground="Gray" Text="{Binding Index, Mode=OneWay, Converter={StaticResource LogTimeConverter}}"/>
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding Path=Voltage, StringFormat={}{0:n2} V, Converter={StaticResource VoltageToFloat}}"/>
                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Path=Current, StringFormat={}{0:d} mA}"/>
                                    <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding Path=Capacity, StringFormat={}{0:n0} mAh, Converter={StaticResource VoltageToFloat}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
