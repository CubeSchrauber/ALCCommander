<Window x:Class="alcwin.DatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        mc:Ignorable="d"
        Style="{StaticResource WindowDefault}"
        Loaded="Window_Loaded"
        SizeToContent="WidthAndHeight"
        Title="Datenbank" d:DesignHeight="450" d:DesignWidth="700">
    <!--<Window.CommandBindings>
        <CommandBinding Command="local:DatabaseWindow.EditCommand" Executed="CommandBinding_Executed"/>
    </Window.CommandBindings>-->
    <Window.Resources>
        <local:BatTypeToString x:Key="BatTypeConverter"/>
        <local:VoltageConverter x:Key="VoltageConverter"/>
        <local:CapacityConverter x:Key="CapacityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Style="{StaticResource DefaultBorder}" Margin="8" Background="White">
            <ListBox x:Name="DbList" Width="450" Height="400" Style="{DynamicResource DbListBoxStyle}" ItemsSource="{Binding Data}" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent">
                            <Grid.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DatabaseWindow}}}" CommandParameter="{Binding}"/>
                            </Grid.InputBindings>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" HorizontalAlignment="Right" Margin="0 0 4 0" Foreground="Gray">
                                <!--<TextBlock.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                                </TextBlock.InputBindings>-->
                                <Run Text="{Binding Index, Mode=OneWay}"/>
                                <Run Text=":"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" HorizontalAlignment="Left" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource VoltageConverter}">
                                        <Binding Path="BatType" Mode="OneWay"/>
                                        <Binding Path="Cells" Mode="OneWay"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource CapacityConverter}">
                                        <Binding Path="BatType"/>
                                        <Binding Path="Capacity"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <Grid Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="Padding" Value="4"/>
                </Style>
            </Grid.Resources>
            <Button  HorizontalAlignment="Left" Click="Edit_Click">
                <Image Source="{StaticResource EditDrawingImage}"/>
            </Button>
            <Button Grid.Row="2" Tag="0" Click="ToChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowRightDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="1" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="3" Tag="1"  Click="ToChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowRightDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="2" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="4" Tag="2"  Click="ToChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowRightDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="3" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="5" Tag="3"  Click="ToChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowRightDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="4" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Window>
