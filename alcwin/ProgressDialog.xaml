<Window x:Class="alcwin.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        mc:Ignorable="d"
        Style="{StaticResource WindowDefault}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        BorderBrush="{StaticResource Border.Borderbrush}" BorderThickness="3"
        Title="ProgressDialog" Height="450" Width="800" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource DefaultBorder}" VerticalAlignment="Center">
                <Image Source="{Binding Path=ImageSource, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Height="100"/>
            </Border>
            <TextBlock Grid.Column="1" Text="Daten laden..." Style="{StaticResource BigText}" VerticalAlignment="Center" Margin="32 0 0 0"/>
        </Grid>
        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Orientation="Horizontal" Height="40" Value="{Binding Path=Progress, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>
