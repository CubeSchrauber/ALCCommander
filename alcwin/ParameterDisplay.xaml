<UserControl x:Class="alcwin.ParameterDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:alcwin"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox" BasedOn="{StaticResource AlcTextBoxStyle}">
                <Setter Property="Width" Value="80"/>
                <Setter Property="IsReadOnly" Value="True"/>
            </Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}"/>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Funktion:"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Akkutyp:"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Kapazität:"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Spannung:"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ladestrom:"/>
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Entladestrom:"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="Function" Grid.ColumnSpan="2" Width="Auto"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="BatType"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="Capacity" HorizontalContentAlignment="Right"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="Voltage" HorizontalContentAlignment="Right"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="ChargeCurrent" HorizontalContentAlignment="Right"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="DischargeCurrent" HorizontalContentAlignment="Right"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="mAh"/>
        <TextBlock Grid.Row="3" Grid.Column="2" Text="V"/>
        <TextBlock Grid.Row="4" Grid.Column="2" Text="mA"/>
        <TextBlock Grid.Row="5" Grid.Column="2" Text="mA"/>
    </Grid>
</UserControl>
