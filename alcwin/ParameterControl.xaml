<UserControl x:Class="alcwin.ParameterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:alcwin"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="460" d:DesignWidth="800">
    <Grid>
        <Grid.Resources>
            <Style TargetType="{x:Type RadioButton}" BasedOn="{StaticResource AlcRadioButtonStyle2}">
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style x:Key="{x:Type Border}" TargetType="Border">
                <Setter Property="BorderBrush" Value="DarkGray"/>
                <Setter Property="CornerRadius" Value="{StaticResource Border.CornerRadius}"/>
                <Setter Property="BorderThickness" Value="{StaticResource Border.BorderThickness}"/>
                <Setter Property="Padding" Value="{StaticResource Border.Padding}"/>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <!--<ColumnDefinition Width="Auto"/>-->
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" TextElement.FontWeight="DemiBold">
            <UniformGrid Margin="4" Columns="1" VerticalAlignment="Stretch">
                <RadioButton x:Name="BatNiCd" GroupName="BatType" Content="NiCd" Tag="0" Click="BatType_Click" IsChecked="True"/>
                <RadioButton x:Name="BatNiMH" GroupName="BatType" Content="NiMH" Tag="1" Click="BatType_Click"/>
                <RadioButton x:Name="BatLiIon" GroupName="BatType" Content="Li-4.1" Tag="2" Click="BatType_Click"/>
                <RadioButton x:Name="BatLiPol" GroupName="BatType" Content="Li-4.2" Tag="3" Click="BatType_Click"/>
                <RadioButton x:Name="BatPb" GroupName="BatType" Content="Pb" Tag="4" Click="BatType_Click"/>
                <RadioButton x:Name="BatLiPeFo4" GroupName="BatType" Content="LiFePO" Tag="5" Click="BatType_Click"/>
                <RadioButton x:Name="BatLi435" GroupName="BatType" Content="Li4.35" Tag="6" Click="BatType_Click"/>
                <RadioButton x:Name="BatNiZn" GroupName="BatType" Content="NiZn" Tag="7" Click="BatType_Click"/>
                <RadioButton x:Name="BatAgmCa" GroupName="BatType" Content="AGM/CA" Tag="8" Click="BatType_Click"/>
            </UniformGrid>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" TextElement.FontWeight="DemiBold">
            <Grid x:Name="VoltageGrid" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
            </Grid>
        </Border>
        <Border Grid.Row="0" Grid.Column="2" Margin="8 0 0 0">
            <Grid x:Name="ParameterGrid" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="NameCaption" Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource Caption}"/>
                <TextBox x:Name="NameEdit" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource AlcTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kapazität:" Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Width="100" x:Name="Capacity" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="mAh" Style="{DynamicResource Caption}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ladestrom:" Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Width="100" x:Name="ChargeCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                <UniformGrid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Columns="4" Margin="0 0 0 8">
                    <UniformGrid.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </UniformGrid.Resources>
                    <Button Content="C/20" Tag="3" Click="ChargeCurrent_Click"/>
                    <Button Content="C/10" Tag="6"  Click="ChargeCurrent_Click"/>
                    <Button Content="C/5" Tag="12"  Click="ChargeCurrent_Click"/>
                    <Button Content="C/3" Tag="20"  Click="ChargeCurrent_Click"/>
                    <Button Content="C/2" Tag="30"  Click="ChargeCurrent_Click"/>
                    <Button Content="C" Tag="60"  Click="ChargeCurrent_Click"/>
                    <Button Content="2*C" Tag="120"  Click="ChargeCurrent_Click"/>
                    <Button Content="4*C" Tag="240"  Click="ChargeCurrent_Click"/>
                </UniformGrid>
                <TextBlock Grid.Row="4" x:Name="FormingCaption" Grid.Column="0" Text="Formierstrom:" Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="4" Grid.Column="1" Width="100" x:Name="FormingCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                <TextBlock Grid.Row="4" x:Name ="FormingUnit" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                <UniformGrid x:Name="FormingButtons" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Columns="4" Margin="0 0 0 8">
                    <UniformGrid.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </UniformGrid.Resources>
                    <Button Content="C/10" Tag="6"  Click="FormingCurrent_Click"/>
                    <Button Content="C/5" Tag="12"  Click="FormingCurrent_Click"/>
                    <Button Content="C/3" Tag="20"  Click="FormingCurrent_Click"/>
                    <Button Content="C/2" Tag="30"  Click="FormingCurrent_Click"/>
                </UniformGrid>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Entladestrom:" Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="6" Grid.Column="1" Width="100" x:Name="DischargeCurrent" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="mA" Style="{DynamicResource Caption}"/>
                <UniformGrid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Columns="4" Margin="0 0 0 8">
                    <UniformGrid.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </UniformGrid.Resources>
                    <Button Content="C/20" Tag="3" Click="DischargeCurrent_Click"/>
                    <Button Content="C/10" Tag="6"  Click="DischargeCurrent_Click"/>
                    <Button Content="C/5" Tag="12"  Click="DischargeCurrent_Click"/>
                    <Button Content="C/3" Tag="20"  Click="DischargeCurrent_Click"/>
                    <Button Content="C/2" Tag="30"  Click="DischargeCurrent_Click"/>
                    <Button Content="C" Tag="60"  Click="DischargeCurrent_Click"/>
                    <Button Content="2*C" Tag="120"  Click="DischargeCurrent_Click"/>
                    <Button Content="4*C" Tag="240"  Click="DischargeCurrent_Click"/>
                </UniformGrid>
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Pause:" Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="8" Grid.Column="1" Width="100" x:Name="Pause" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                <TextBlock Grid.Row="8" Grid.Column="2" Text="min" Style="{DynamicResource Caption}"/>
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Vollfaktor:" Style="{DynamicResource Caption}"/>
                <TextBox Grid.Row="9" Grid.Column="1" Width="100" x:Name="FillFactor" Style="{DynamicResource AlcTextBoxStyle}" HorizontalContentAlignment="Right"/>
                <TextBlock Grid.Row="9" Grid.Column="2" Text="%" Style="{DynamicResource Caption}"/>
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Aktivator:" Style="{StaticResource Caption}"/>
                <CheckBox Grid.Row="10" Grid.Column="1" Content="Aktivator" x:Name="Activator" Style="{StaticResource AlcCheckBoxStyle}" Margin="0 2"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
