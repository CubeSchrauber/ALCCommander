<Window x:Class="alcwin.SerialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        mc:Ignorable="d"
        Style="{StaticResource WindowDefault}"
        SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Title="Schnittstelle auswählen" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="8">
        <Grid.Resources>
            <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                <Setter Property="Padding" Value="4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Text="Serial Port:" VerticalAlignment="Center" Margin="0 0 8 0"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="PortSelection"  VerticalAlignment="Center" Margin="8"/>
        <Button Grid.Row="0" Grid.Column="2"  Content="Verbinden" IsDefault="True" Click="Serial_Click"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Netzwerk:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Width="250" x:Name="Hostname" VerticalAlignment="Center" Margin="8" Style="{StaticResource AlcTextBoxStyle}"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Verbinden" Click="Network_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Abbrechen" IsCancel="True" Margin="0 8 0 0"/>
    </Grid>
</Window>
