<Window x:Class="alcwin.DatabaseEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:alcwin"
        Style="{StaticResource WindowDefault}"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Title="Datenbankeintrag bearbeiten" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <local:ParameterControl x:Name="ParameterControl"/>
        <Grid Grid.Column="1" Margin="8 0 0 0">
            <Grid.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource AlcButtonStyle}">
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="Width" Value="140"/>
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Content="Ok" IsDefault="True" Click="Ok_Click"/>
            <Button Grid.Row="1" Content="Abbrechen" IsCancel="True" Margin="0 8 0 0"/>
            <Button Grid.Row="3" Tag="0" Click="FromChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowLeftDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="1" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="4" Margin="0 8 0 0" Tag="1" Click="FromChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowLeftDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="2" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="5" Margin="0 8 0 0" Tag="2" Click="FromChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowLeftDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="3" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
            <Button Grid.Row="6" Margin="0 8 0 0" Tag="3" Click="FromChannel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{StaticResource ArrowLeftDrawingImage}" Margin="6"/>
                    <TextBlock Grid.Column="1" Text="4" Style="{StaticResource Caption}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Image Grid.Column="2" Source="{StaticResource ChannelDrawingImage}" Margin="0 0 4 0"/>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Window>
